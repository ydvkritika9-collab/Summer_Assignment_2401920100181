class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        ListNode* fast=head;
        ListNode* slow=head;
        if(head==nullptr || head->next==nullptr){
                return head;
            }
            
        
        while(fast!=nullptr && fast->next!=nullptr){
            
            fast=fast->next->next;
            slow=slow->next;
            
        }
        
        return slow;
        
    }
};
